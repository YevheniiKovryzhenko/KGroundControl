{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 16,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-base",
      "hidden": true,
      "generator": "Visual Studio 17 2022"
    },
    {
        "name": "linux-base",
        "hidden": true,
        "generator": "Ninja",
        "cacheVariables": {
          "CMAKE_MAKE_PROGRAM": "ninja",
          "CMAKE_C_COMPILER": "gcc",
          "CMAKE_CXX_COMPILER": "g++",
          "CMAKE_INTERPROCEDURAL_OPTIMIZATION_RELEASE": "ON",
          "CMAKE_INTERPROCEDURAL_OPTIMIZATION_MINSIZEREL": "ON",
          "CMAKE_C_FLAGS_RELEASE": "-O3 -DNDEBUG -flto -fno-plt -ffunction-sections -fdata-sections -fomit-frame-pointer",
          "CMAKE_CXX_FLAGS_RELEASE": "-O3 -DNDEBUG -flto -fno-plt -ffunction-sections -fdata-sections -fomit-frame-pointer",
          "CMAKE_EXE_LINKER_FLAGS_RELEASE": "-Wl,--gc-sections",
          "CMAKE_SHARED_LINKER_FLAGS_RELEASE": "-Wl,--gc-sections",
          "CMAKE_C_FLAGS_MINSIZEREL": "-Os -DNDEBUG -flto -ffunction-sections -fdata-sections -fomit-frame-pointer",
          "CMAKE_CXX_FLAGS_MINSIZEREL": "-Os -DNDEBUG -flto -ffunction-sections -fdata-sections -fomit-frame-pointer",
          "CMAKE_EXE_LINKER_FLAGS_MINSIZEREL": "-Wl,--gc-sections -s",
          "CMAKE_SHARED_LINKER_FLAGS_MINSIZEREL": "-Wl,--gc-sections -s"
    }
    },
    {
      "name": "Debug (Windows)",
      "inherits": ["windows-base"],
      "displayName": "Debug (Windows)",
      "binaryDir": "${sourceDir}/build/Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "MinSizeRel (Windows)",
      "inherits": ["windows-base"],
      "displayName": "MinSizeRel (Windows)",
      "binaryDir": "${sourceDir}/build/MinSizeRel",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "MinSizeRel"
      }
    },
    {
      "name": "Release (Windows)",
      "inherits": ["windows-base"],
      "displayName": "Release (Windows)",
      "binaryDir": "${sourceDir}/build/Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "Debug (Linux)",
      "inherits": ["linux-base"],
      "displayName": "Debug (Linux)",
      "binaryDir": "${sourceDir}/build/Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "MinSizeRel (Linux)",
      "inherits": ["linux-base"],
      "displayName": "MinSizeRel (Linux)",
      "binaryDir": "${sourceDir}/build/MinSizeRel",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "MinSizeRel"
      }
    },
    {
      "name": "Release (Linux)",
      "inherits": ["linux-base"],
      "displayName": "Release (Linux)",
      "binaryDir": "${sourceDir}/build/Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
